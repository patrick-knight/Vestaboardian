{
  "name": "vestaboardian",
  "version": "0.1.3",
  "description": "Send a Vestaboard message composed in an Obsidian note.",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit && node esbuild.config.mjs production",
    "test": "vitest run",
    "lint": "eslint src tests",
    "test:watch": "vitest"
  },
  "keywords": [
    "obsidian",
    "vestaboard"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.4.1",
    "jsdom": "^29.1.1",
    "obsidian": "^1.7.2",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  }
}
